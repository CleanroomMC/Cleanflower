package pkg;

public class TestAssignmentSwitchExpression6 {
   public void test(String directionStr, int i) {
      String axis;
      for (axis = directionStr; i > 0; axis = switch (directionStr.toLowerCase()) {// 5 6 8
         case "north", "south" -> "y";// 11
         case "east", "west" -> "x";// 14
         case "up", "down" -> "z";// 17
         default -> throw new IllegalStateException("Unexpected value: " + directionStr);// 19
      }) {
         i--;// 7
      }

      System.out.println(axis);// 23
   }// 24
}

