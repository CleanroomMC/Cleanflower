package pkg;

public class TestStringSwitchTypes {
   public int testSplit(String s) {
      int res = 0;// 5
      switch (s) {// 6
         case "a":
            res = 1;// 8
            break;// 9
         case "b":
            res = 2;// 11
            break;// 12
         case "c":
            res = 4;// 14
      }

      return res;// 17
   }

   public int testSplit2(String s) {
      return switch (s) {// 21
         case "a" -> 1;// 22
         case "b" -> 2;// 23
         case "c" -> 4;// 24
         default -> 0;// 25
      };
   }

   public String testInlineSplit(String s) {
      String res = "";// 30
      switch (s) {// 31
         case "a":
            res = "a";// 33
         default:
            return res;// 37
      }
   }

   public int testSplitDup(String s) {
      switch (s) {// 41
         case "a":
            return 1;// 43
         case "b":
            return 1;// 45
         default:
            System.out.println("Test");// 47
            return 0;// 48
      }
   }
}

